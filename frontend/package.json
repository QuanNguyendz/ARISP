    "@tanstack/react-query": "^5.51.21",
    "axios": "^1.7.2",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "dayjs": "^1.11.12",
    "docx-preview": "^0.3.7",
    "framer-motion": "^12.40.0",
    "i18next": "^23.16.8",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^1.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-grid-layout": "^1.5.3",
